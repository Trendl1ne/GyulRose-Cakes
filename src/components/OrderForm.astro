---
import { site } from "../data/site";
import { getCollection } from "astro:content";
const webhook = import.meta.env.PUBLIC_ORDER_WEBHOOK_URL || site.orderWebhook;
const { compact = false } = Astro.props;
const cakeOptions = (await getCollection("cakes", ({ data }) => data.published)).map((entry) => entry.data.title).sort((a, b) => a.localeCompare(b));
---
<form id="quote-form" class:list={["quote-form", { compact }]} data-webhook={webhook} data-whatsapp={site.phoneInternational} novalidate>
  <div class="form-intro">
    <p class="eyebrow">Quick cake enquiry</p>
    <h2>Order your custom cake</h2>
    <p>Send the essentials and GyulRose will contact you by email or phone to confirm availability, design and price.</p>
  </div>

  <section class="price-guide" aria-labelledby="price-guide-title">
    <h3 id="price-guide-title">Cake size & pricing guide</h3>
    <div class="price-grid">
      <div><strong>6 inch</strong><span>From £35</span></div>
      <div><strong>8 inch</strong><span>From £45</span></div>
      <div><strong>10 inch</strong><span>From £60</span></div>
      <div><strong>12 inch</strong><span>From £75</span></div>
      <div><strong>14 inch</strong><span>From £90</span></div>
      <div><strong>16 inch</strong><span>From £120</span></div>
    </div>
    <p><strong>Important:</strong> These are starting prices. The final price depends on the design, decoration and any special requests.</p>
  </section>

  <div id="cake-selection" class="cake-selection">
    <label for="selected-cake"><span>Choose or search for a cake</span>
      <input id="selected-cake" name="selectedCake" autocomplete="off" placeholder="Choose a cake or type to search…" role="combobox" aria-autocomplete="list" aria-controls="cake-options" aria-expanded="false" />
    </label>
    <div id="cake-options" class="cake-options" role="listbox" aria-label="Available cakes" hidden>
      {cakeOptions.map((title) => <button type="button" role="option" data-cake-option={title}>{title}</button>)}
      <button type="button" role="option" data-cake-option="Your own idea">Your own idea</button>
      <p class="cake-options-empty" hidden>No matching cake. Continue typing to describe your own idea.</p>
    </div>
    <p>Pick from the gallery or type your own idea.</p>
  </div>
  <div class="form-grid">
    <label>Full name *<input name="fullName" autocomplete="name" required /></label>
    <label>Email address *<input name="emailAddress" type="email" autocomplete="email" required /></label>
    <label>Phone number *<input name="phoneNumber" type="tel" autocomplete="tel" required /></label>
    <label>Date needed *<input name="eventDate" type="date" required /></label>
    <label>Cake size *<select name="cakeSize" required><option value="">Choose size</option><option>6 inch</option><option>8 inch</option><option>10 inch</option><option>12 inch</option><option>14 inch</option><option>16 inch</option><option>Not sure yet</option></select></label>
    <label>Preferred flavour<select name="flavour"><option value="">Discuss with GyulRose</option><option>Vanilla</option><option>Chocolate</option><option>Strawberry</option><option>Blueberry</option><option>Lemon</option><option>Pistachio</option><option>Red velvet</option><option>Carrot</option><option>Oreo</option><option>Biscoff</option><option>Other</option></select></label>
    <label class="full">Anything important?<textarea name="designDetails" rows="3" placeholder="Colour, name, age, theme or allergy. You can also send a photo on WhatsApp."></textarea></label>
  </div>

  <label class="consent"><input type="checkbox" name="privacyAccepted" required /> <span>I agree that my details can be used to answer this enquiry. <a href="/privacy/" target="_blank">Privacy notice</a> *</span></label>
  <input class="honeypot" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <div class="submit-row">
    <button class="button" type="submit">Submit order request</button>
  </div>
  <p class="form-reassurance">No payment now. Your date is confirmed only after GyulRose replies.</p>
  <div id="form-status" role="status" aria-live="polite"></div>
  <div class="direct-contact">
    <p>Or contact us directly:</p>
    <a class="whatsapp-order" href={site.whatsapp("Hello! I would like to place a custom cake order.")} target="_blank" rel="noreferrer">Chat with us on WhatsApp</a>
  </div>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>("#quote-form");
  const status = document.querySelector<HTMLElement>("#form-status");
  const selectedCake = document.querySelector<HTMLInputElement>("#selected-cake");
  const cakeOptionsPanel = document.querySelector<HTMLElement>("#cake-options");
  const cakeOptionButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-cake-option]"));
  const cakeOptionsEmpty = document.querySelector<HTMLElement>(".cake-options-empty");

  const showCakeOptions = () => {
    if (!selectedCake || !cakeOptionsPanel) return;
    cakeOptionsPanel.hidden = false;
    selectedCake.setAttribute("aria-expanded", "true");
  };

  const hideCakeOptions = () => {
    if (!selectedCake || !cakeOptionsPanel) return;
    cakeOptionsPanel.hidden = true;
    selectedCake.setAttribute("aria-expanded", "false");
  };

  const filterCakeOptions = () => {
    const query = selectedCake?.value.trim().toLocaleLowerCase() ?? "";
    let visible = 0;
    cakeOptionButtons.forEach((button) => {
      const matches = !query || (button.dataset.cakeOption ?? "").toLocaleLowerCase().includes(query);
      button.hidden = !matches;
      if (matches) visible += 1;
    });
    if (cakeOptionsEmpty) cakeOptionsEmpty.hidden = visible > 0;
  };

  const setCake = (cake: string) => {
    if (selectedCake) selectedCake.value = cake;
    filterCakeOptions();
    hideCakeOptions();
  };

  const cakeFromUrl = new URLSearchParams(window.location.search).get("cake");
  if (cakeFromUrl) setCake(cakeFromUrl);

  selectedCake?.addEventListener("focus", () => { filterCakeOptions(); showCakeOptions(); });
  selectedCake?.addEventListener("click", () => { filterCakeOptions(); showCakeOptions(); });
  selectedCake?.addEventListener("input", () => { filterCakeOptions(); showCakeOptions(); });
  selectedCake?.addEventListener("keydown", (event) => {
    if (event.key === "Escape") hideCakeOptions();
  });
  cakeOptionButtons.forEach((button) => button.addEventListener("click", () => setCake(button.dataset.cakeOption ?? "")));
  document.addEventListener("click", (event) => {
    if (!(event.target as HTMLElement).closest("#cake-selection")) hideCakeOptions();
  });

  document.addEventListener("click", (event) => {
    const trigger = (event.target as HTMLElement).closest<HTMLElement>("[data-select-cake]");
    if (!trigger) return;
    event.preventDefault();
    setCake(trigger.dataset.selectCake ?? "Your own idea");
    document.querySelector("#order")?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  const setStatus = (message: string, kind: "success" | "error" | "info") => {
    if (!status) return;
    status.textContent = message;
    status.dataset.kind = kind;
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;
    const values = Object.fromEntries(new FormData(form).entries());
    if (values.website) return;
    const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
    if (button) { button.disabled = true; button.textContent = "Preparing…"; }
    const payload = {
      ...values,
      cakeFlavor: values.flavour || "To discuss",
      cakeShape: "To discuss",
      deliveryDate: values.eventDate,
      specialRequests: `Selected cake: ${values.selectedCake || "Your own idea"}\n${values.designDetails || "No additional notes yet."}`,
      submissionTime: new Date().toISOString(),
      sourcePage: window.location.href,
      submittedAt: new Date().toISOString()
    };
    const webhook = form.dataset.webhook ?? "";
    try {
      if (webhook) {
        const response = await fetch(webhook, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        if (!response.ok) throw new Error(`The enquiry service returned ${response.status}`);
        setStatus("Your enquiry was sent. GyulRose will contact you to confirm the details.", "success");
        form.reset(); setCake("");
      } else {
        const lines = [
          "Hello GyulRose Cakes, I would like to check a cake order.",
          `Cake: ${values.selectedCake}`,
          `Name: ${values.fullName}`,
          `Phone: ${values.phoneNumber}`,
          `Date: ${values.eventDate}`,
          `Size: ${values.cakeSize}`,
          `Flavour: ${values.flavour || "To discuss"}`,
          `Notes: ${values.designDetails || "None yet"}`
        ];
        window.open(`https://wa.me/${form.dataset.whatsapp}?text=${encodeURIComponent(lines.join("\n"))}`, "_blank", "noopener,noreferrer");
        setStatus("Your enquiry is ready in WhatsApp. Press Send there to contact GyulRose.", "info");
      }
    } catch (error) {
      console.error(error);
      setStatus("The enquiry was not confirmed as delivered. Please use the WhatsApp link.", "error");
    } finally {
      if (button) { button.disabled = false; button.textContent = "Submit order request"; }
    }
  });
</script>

<style>
  .quote-form { max-width: 930px; margin: 0 auto; background: #fff; border: 1px solid var(--line); border-radius: 28px; padding: clamp(22px, 4vw, 38px); box-shadow: var(--shadow); }
  .form-intro { max-width: 680px; margin-bottom: 22px; }
  .form-intro h2 { margin-bottom: 10px; }
  .form-intro > p:last-child { color: var(--muted); }
  .price-guide { margin:0 0 20px; padding:18px; background:#fffaf7; border:1px solid var(--line); border-radius:16px; }
  .price-guide h3 { margin-bottom:14px; text-align:center; font-size:1.25rem; }
  .price-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:9px; }
  .price-grid div { display:flex; flex-direction:column; align-items:center; padding:10px 8px; background:#f7f0e8; border-radius:10px; text-align:center; }
  .price-grid strong { font-size:.86rem; }
  .price-grid span { color:var(--rose-dark); font-weight:700; font-size:.82rem; font-variant-numeric:tabular-nums; }
  .price-guide > p { margin:12px 0 0; color:#665750; font-size:.78rem; line-height:1.45; text-align:center; }
  .cake-selection { background: var(--blush); border: 1px solid #e7cfc8; border-radius: 15px; padding: 14px 15px; margin-bottom: 20px; }
  .cake-selection label { gap: 7px; }
  .cake-selection span { color: var(--rose-dark); font-size: .9rem; }
  .cake-selection input { background:#fff; font-weight:700; }
  .cake-options { max-height:280px; margin-top:7px; overflow-y:auto; overscroll-behavior:contain; background:#fff; border:1px solid #bdaaa0; border-radius:12px; box-shadow:0 14px 30px rgba(90,74,66,.14); }
  .cake-options[hidden] { display:none; }
  .cake-options button { display:block; width:100%; padding:10px 12px; color:var(--ink); background:#fff; border:0; border-bottom:1px solid #eee4de; text-align:left; font:inherit; font-weight:600; cursor:pointer; }
  .cake-options button[hidden] { display:none; }
  .cake-options button:last-of-type { color:var(--rose-dark); border-bottom:0; }
  .cake-options button:hover,.cake-options button:focus-visible { background:#fff4ef; outline:none; }
  .cake-options-empty { padding:12px; }
  .cake-selection p { margin:7px 0 0; color:#665750; font-size:.8rem; }
  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  label { display:flex; flex-direction:column; gap:6px; font-weight:700; font-size:.9rem; }
  input,select,textarea { width:100%; border:1px solid #bdaaa0; border-radius:12px; padding:11px 12px; background:#fff; color:var(--ink); }
  textarea { resize: vertical; }
  input:focus,select:focus,textarea:focus { outline:3px solid rgba(156,67,87,.2); border-color:var(--rose); }
  .full { grid-column:1/-1; }
  .consent { flex-direction:row; align-items:flex-start; font-weight:500; margin-top:18px; }
  .consent input { width:auto; margin-top:5px; }
  .submit-row { display:flex; flex-wrap:wrap; align-items:center; gap:16px; margin-top:20px; }
  .form-reassurance { margin: 12px 0 0; color: var(--muted); font-size: .84rem; }
  .direct-contact { margin-top:22px; padding-top:20px; border-top:1px solid var(--line); text-align:center; }
  .direct-contact p { margin:0 0 12px; color:var(--muted); }
  .whatsapp-order { display:inline-flex; align-items:center; justify-content:center; min-height:48px; padding:12px 24px; color:#fff; background:linear-gradient(135deg,#25d366,#128c7e); border-radius:999px; box-shadow:0 10px 24px rgba(18,140,126,.2); font-weight:700; text-decoration:none; transition:transform .2s ease,box-shadow .2s ease; }
  .whatsapp-order:hover { transform:translateY(-2px); box-shadow:0 14px 30px rgba(18,140,126,.28); }
  #form-status { margin-top:14px; }
  #form-status:not(:empty) { padding:13px; border-radius:12px; }
  #form-status[data-kind="success"] { background:#e4f3ea; color:#174d32; }
  #form-status[data-kind="error"] { background:#fbe7e7; color:#7f2525; }
  #form-status[data-kind="info"] { background:#e8f0f7; color:#244e70; }
  .honeypot { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); clip-path:inset(50%); white-space:nowrap; border:0; }
  @media(max-width:700px){
    .price-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .form-grid{grid-template-columns:1fr}.full{grid-column:auto}
    .submit-row .button { width:100%; }
    .whatsapp-order { width:100%; }
  }
</style>
