---
import { site } from "../data/site";
import SocialLinks from "./SocialLinks.astro";
---
<footer>
  <div class="container footer-grid">
    <div>
      <a class="footer-wordmark" href="/" aria-label="Gyulrose Cakes home"><img src="/images/gyulrose-logo.webp" alt="" width="64" height="64" /><span>Gyulrose Cakes</span></a>
      <p>Made-to-order cakes in Haywards Heath, West Sussex.</p>
      <a href={site.whatsapp("Hello GyulRose Cakes, I would like to ask about a cake.")} target="_blank" rel="noreferrer">{site.phoneDisplay}</a>
      <div class="footer-social"><SocialLinks /></div>
    </div>
    <div>
      <strong>Explore</strong>
      <a href="/gallery/">Cake gallery</a>
      <a href="/pricing-flavours/">Prices and flavours</a>
      <a href="/delivery-areas/">Delivery and collection</a>
      <a href="/order/">Request a quote</a>
    </div>
    <div>
      <strong>Information</strong>
      <a href="/allergens/">Allergen information</a>
      <a href="/privacy/">Privacy</a>
      <a href="/ordering-terms/">Ordering terms</a>
    </div>
  </div>
  <div class="container footer-bottom">© {new Date().getFullYear()} GyulRose Cakes. All rights reserved.</div>
</footer>
<style>
  footer { background: #302724; color: #f9f3ef; padding: 56px 0 24px; }
  .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 42px; }
  .footer-wordmark { display:flex; align-items:center; gap:12px; color:#f9f3ef; font-family:"Playfair Display",serif; font-weight:700; font-size:1.7rem; text-decoration:none; line-height:1.1; }
  .footer-wordmark img { width:58px; height:58px; border-radius:50%; }
  footer strong, footer a { display: block; }
  footer a { margin-top: 10px; color: #f9f3ef; }
  .footer-social { margin-top:18px; }
  .footer-social :global(a) { margin-top:0; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,.18); margin-top: 42px; padding-top: 20px; font-size: .85rem; color: #d8cbc5; }
  @media(max-width: 700px) { .footer-grid { grid-template-columns: 1fr; gap: 28px; } }
</style>
