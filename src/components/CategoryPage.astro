---
import BaseLayout from "../layouts/BaseLayout.astro";
import CakeCard from "./CakeCard.astro";
import { site } from "../data/site";
import { optimizedCakeImage } from "../data/images";

const { title, heading, description, eyebrow, cakes, intro, faq = [] } = Astro.props;
const faqSchema = faq.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
} : undefined;
---
<BaseLayout title={title} description={description} schema={faqSchema}>
  <section class="section category-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{heading}</h1>
        <p class="lead">{description}</p>
        <div class="actions">
          <a class="button" href="/order/">Request a quote</a>
          <a class="button button--secondary" href={site.whatsapp(`Hello GyulRose Cakes, I would like to ask about ${heading.toLowerCase()}.`)} target="_blank" rel="noreferrer">Ask on WhatsApp</a>
        </div>
      </div>
      {cakes[0] && <img class="hero-photo" src={optimizedCakeImage(cakes[0].data.slug)} alt={cakes[0].data.imageAlt} width="720" height="720" />}
    </div>
  </section>
  <section class="section section--white">
    <div class="container">
      <div class="prose"><p class="lead">{intro}</p></div>
      <div class="grid grid--3 cake-grid">{cakes.slice(0, 12).map((entry: any) => <CakeCard cake={entry.data} />)}</div>
      <div class="actions"><a class="button button--secondary" href="/gallery/">View the complete gallery</a></div>
    </div>
  </section>
  {faq.length > 0 && <section class="section section--blush"><div class="container"><p class="eyebrow">Before you enquire</p><h2>Common questions</h2><div class="faq-grid">{faq.map((item: any) => <details><summary>{item.question}</summary><p>{item.answer}</p></details>)}</div></div></section>}
</BaseLayout>
<style>
  .hero-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: 48px; align-items: center; }
  .hero-photo { width: 100%; max-height: 620px; aspect-ratio: 1/1; object-fit: cover; border-radius: 30px; box-shadow: var(--shadow); }
  .cake-grid { margin-top: 36px; }
  .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 28px; }
  details { background: #fff; padding: 20px; border-radius: 16px; border: 1px solid var(--line); }
  summary { font-weight: 700; cursor: pointer; }
  details p { margin: 12px 0 0; color: var(--muted); }
  @media(max-width: 800px) { .hero-grid, .faq-grid { grid-template-columns: 1fr; } }
</style>
