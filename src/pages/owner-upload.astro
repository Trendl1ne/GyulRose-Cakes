---
import BaseLayout from "../layouts/BaseLayout.astro";
const webhook = import.meta.env.PUBLIC_CAKE_UPLOAD_WEBHOOK_URL ?? "";
---
<BaseLayout title="Owner Cake Upload" description="Private cake upload page for the Gyulrose Cakes owner." noindex>
  <section class="section owner-page">
    <div class="container owner-wrap">
      <div class="owner-intro"><p class="eyebrow">Private owner tool</p><h1>Add a cake to the gallery</h1><p class="lead">One photograph and the essential cake details. No GitHub access is needed.</p></div>
      <form id="owner-upload-form" class="owner-form" data-webhook={webhook} enctype="multipart/form-data" novalidate>
        <label>Private access code *<input name="accessCode" type="password" autocomplete="current-password" required /></label>
        <label>Cake photograph *<input name="cakeImage" type="file" accept="image/jpeg,image/png,image/webp" required /><small>JPG, PNG or WebP. Maximum 10 MB.</small></label>
        <div class="grid-two">
          <label>Cake name *<input name="title" required placeholder="Pink floral 30th birthday cake" /></label>
          <label>Starting price (£) *<input name="priceFrom" type="number" min="0" step="1" required /></label>
          <label>Category *<select name="category" required><option value="">Choose category</option><option value="birthday">Birthday cakes</option><option value="children-themed">Children's and themed cakes</option><option value="celebration">Celebration cakes</option><option value="corporate">Corporate cakes</option></select></label>
          <label>Flavour *<input name="flavour" required placeholder="Vanilla and strawberry" /></label>
        </div>
        <label>Short description *<textarea name="description" rows="3" minlength="30" maxlength="350" required></textarea></label>
        <label>Ingredients shown *<textarea name="ingredients" rows="3" required placeholder="Sponge, filling, buttercream and decorations shown"></textarea></label>
        <label>Photo description *<input name="imageAlt" required placeholder="Pink floral birthday cake with gold details" /></label>
        <label class="check"><input name="featured" type="checkbox" value="true" /> <span>Feature this cake on the homepage</span></label>
        <input name="published" type="hidden" value="true" />
        <button class="button" type="submit">Send cake for publishing</button>
        <div id="upload-status" role="status" aria-live="polite"></div>
      </form>
    </div>
  </section>
</BaseLayout>
<script>
  const form = document.querySelector<HTMLFormElement>("#owner-upload-form");
  const status = document.querySelector<HTMLElement>("#upload-status");
  const setStatus = (text: string, kind: string) => { if (status) { status.textContent = text; status.dataset.kind = kind; } };
  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;
    const file = form.querySelector<HTMLInputElement>('input[type="file"]')?.files?.[0];
    if (!file) return;
    if (file.size > 10 * 1024 * 1024) { setStatus("Please choose an image smaller than 10 MB.", "error"); return; }
    const webhook = form.dataset.webhook ?? "";
    if (!webhook) { setStatus("Local preview is ready. Connect the private n8n upload webhook before production.", "info"); return; }
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (button) { button.disabled = true; button.textContent = "Uploading…"; }
    try {
      const response = await fetch(webhook, { method:"POST", body:new FormData(form) });
      if (!response.ok) throw new Error(`Upload service returned ${response.status}`);
      setStatus("Cake received successfully. It will appear after approval and the website build.", "success");
      form.reset();
    } catch (error) {
      console.error(error); setStatus("The upload was not confirmed. Please contact Gyunay before trying again.", "error");
    } finally { if (button) { button.disabled = false; button.textContent = "Send cake for publishing"; } }
  });
</script>
<style>
  .owner-page { background:linear-gradient(145deg,var(--blush),var(--cream)); }
  .owner-wrap { max-width:820px; }
  .owner-intro { margin-bottom:28px; }
  .owner-intro h1 { font-size:clamp(2.3rem,6vw,4.2rem); }
  .owner-form { display:grid; gap:17px; background:#fff; padding:clamp(22px,5vw,40px); border:1px solid var(--line); border-radius:28px; box-shadow:var(--shadow); }
  .owner-form label { display:flex; flex-direction:column; gap:7px; font-weight:700; }
  .owner-form input,.owner-form select,.owner-form textarea { width:100%; padding:12px; border:1px solid #bdaaa0; border-radius:12px; }
  .owner-form small { color:var(--muted); font-weight:400; }
  .grid-two { display:grid; grid-template-columns:1fr 1fr; gap:17px; }
  .check { flex-direction:row !important; align-items:center; font-weight:500 !important; }
  .check input { width:auto; }
  #upload-status:not(:empty) { padding:13px; border-radius:12px; }
  #upload-status[data-kind="success"] { background:#e4f3ea;color:#174d32; }
  #upload-status[data-kind="error"] { background:#fbe7e7;color:#7f2525; }
  #upload-status[data-kind="info"] { background:#e8f0f7;color:#244e70; }
  @media(max-width:650px){.grid-two{grid-template-columns:1fr}}
</style>
