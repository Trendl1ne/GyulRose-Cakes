---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CakeCard from "../components/CakeCard.astro";
import OrderForm from "../components/OrderForm.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { site } from "../data/site";
import { optimizedCakeImage } from "../data/images";

const cakes = (await getCollection("cakes", ({ data }) => data.published)).sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const featured = cakes.slice(0, 6);
const hero = cakes.find((cake) => cake.data.image.includes("9f3a8b4f")) ?? cakes[0];
const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Bakery"],
  name: site.name,
  url: site.domain,
  image: new URL(hero.data.image, site.domain).toString(),
  telephone: site.phoneDisplay,
  email: site.email,
  priceRange: "££",
  address: {
    "@type": "PostalAddress",
    addressLocality: site.locality,
    addressRegion: site.region,
    addressCountry: site.country
  },
  areaServed: [site.locality, site.region],
  sameAs: [site.instagram, site.tiktok]
};
---
<BaseLayout title="Custom Cakes in Haywards Heath, West Sussex" description={site.primaryDescription} image={hero.data.image} schema={schema}>
  <section id="home" class="hero section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Made in Haywards Heath, West Sussex</p>
        <h1>Elegant Cakes for Every Occasion</h1>
        <p class="slogan">Sweet elegance in every slice</p>
        <p class="lead">GyulRose Cakes creates elegant, handcrafted cakes for every occasion, blending European recipes with love and creativity. From birthdays to weddings, each cake tells your unique story through taste and beauty.</p>
        <div class="actions">
          <a class="button" href="#order">Order now</a>
          <a class="button button--secondary" href="/gallery/">View gallery</a>
        </div>
        <div class="hero-social"><span>See the latest cakes</span><SocialLinks /></div>
      </div>
      <div class="hero-visual" aria-label="Featured Gyulrose cake creation">
        <figure class="hero-slide"><img src={optimizedCakeImage(hero.data.slug)} alt={hero.data.imageAlt} width="820" height="920" fetchpriority="high" /><figcaption><span>{hero.data.flavour}</span><strong>{hero.data.title}</strong><small>From £{hero.data.priceFrom}</small></figcaption></figure>
        <div class="motion-badge"><span>Real cakes</span><strong>Made to order</strong></div>
      </div>
    </div>
  </section>
  <section id="cakes" class="section gallery-preview">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Real GyulRose creations</p><h2>Our cake gallery</h2><p>Browse six customer favourites here, or open the full gallery to explore every cake.</p></div></div>
      <div class="grid grid--3">{featured.map((cake, index) => <CakeCard cake={cake.data} priority={index < 2} />)}</div>
      <div class="show-all"><a class="button" href="/gallery/">Show all cakes</a></div>
    </div>
  </section>

  <section id="order" class="section order-section">
    <div class="container">
      <OrderForm compact />
    </div>
  </section>

  <section id="contact" class="section contact-section">
    <div class="container">
      <p class="eyebrow">Get in touch</p>
      <h2>Choose the easiest way to contact GyulRose</h2>
      <div class="contact-grid">
        <a class="contact-card" href={`mailto:${site.email}`}><span aria-hidden="true">&#9993;</span><strong>Email</strong><p>Send detailed requirements or reply to an order enquiry.</p><small>{site.email}</small></a>
        <a class="contact-card" href={site.whatsapp("Hello GyulRose Cakes, I would like to ask about a cake.")} target="_blank" rel="noreferrer"><span aria-hidden="true">&#9742;</span><strong>WhatsApp</strong><p>Ask a quick question or send a cake inspiration photo.</p><small>{site.phoneDisplay}</small></a>
        <a class="contact-card" href="/delivery-areas/"><span aria-hidden="true">&#8962;</span><strong>Haywards Heath</strong><p>Collection and available delivery across nearby West Sussex.</p><small>View delivery information</small></a>
      </div>
      <div class="contact-social"><span>See the latest cakes</span><SocialLinks /></div>
    </div>
  </section>
</BaseLayout>
<style>
  .hero { overflow: hidden; }
  .hero.section { padding: 34px 0; min-height:calc(100svh - 76px); display:grid; align-items:center; }
  .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 54px; align-items: center; }
  .hero-copy { padding: 10px 0; }
  .hero-copy h1 { font-size:clamp(2.9rem, 5.4vw, 4.7rem); max-width:12ch; }
  .slogan { color:var(--gold); font-family:"Playfair Display",serif; font-style:italic; font-size:clamp(1.15rem,2vw,1.45rem); font-weight:600; margin-top:-4px; }
  .hero-social { display:flex; align-items:center; flex-wrap:wrap; gap:12px; margin-top:20px; color:var(--muted); font-size:.85rem; }
  .hero-visual { position: relative; height:min(68vh,660px); perspective:1200px; }
  .hero-slide { position:absolute; inset:0; display:grid; grid-template-rows:minmax(0,1fr) auto; gap:10px; margin:0; animation:hero-breathe 10s ease-in-out infinite alternate; }
  .hero-slide img { width:100%; height:100%; min-height:0; object-fit:contain; object-position:center; background:#f7f0e8; border-radius:34px; box-shadow:0 26px 70px rgba(63,42,35,.2); }
  .hero-slide figcaption { display:grid; grid-template-columns:1fr auto; gap:2px 12px; padding:10px 16px; color:var(--ink); background:rgba(255,250,246,.94); border:1px solid rgba(117,69,61,.14); border-radius:14px; box-shadow:0 12px 30px rgba(63,42,35,.08); }
  .hero-slide figcaption span { grid-column:1/-1; text-transform:uppercase; letter-spacing:.1em; font-size:.65rem; }
  .hero-slide figcaption strong { font-family:"Playfair Display",serif; font-size:1.08rem; }
  .hero-slide figcaption small { align-self:center; }
  .motion-badge { position:absolute; z-index:6; right:-22px; top:18px; width:104px; aspect-ratio:1; display:grid; place-content:center; text-align:center; color:#3f342e; background:linear-gradient(135deg,var(--rose),#c9a665); border-radius:50%; box-shadow:var(--shadow); animation:badge-turn 16s linear infinite; }
  .motion-badge span,.motion-badge strong{display:block}.motion-badge span{font-size:.64rem;text-transform:uppercase;letter-spacing:.1em}.motion-badge strong{font-family:"Playfair Display",serif;max-width:8ch;line-height:1.05}
  .gallery-preview { background:#fff; }
  .order-section { background: linear-gradient(135deg, #f7f0e8, #f9e6e6); scroll-margin-top: 70px; }
  .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 32px; }
  .section-heading p { color:var(--muted); max-width:62ch; }
  .show-all { display:flex; justify-content:center; margin-top:36px; }
  .contact-section { background:#fff; text-align:center; }
  .contact-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:24px; margin-top:34px; text-align:center; }
  .contact-card { display:flex; flex-direction:column; align-items:center; min-height:230px; padding:28px; border-radius:var(--radius); background:var(--cream); border:1px solid var(--line); text-decoration:none; box-shadow:0 10px 30px rgba(90,74,66,.07); transition:transform .25s ease,box-shadow .25s ease; }
  .contact-card:hover { transform:translateY(-4px); box-shadow:var(--shadow); }
  .contact-card > span { display:grid; place-items:center; width:52px; height:52px; margin-bottom:14px; color:#3f342e; background:var(--gold); border-radius:50%; font-size:1.4rem; }
  .contact-card strong { font-family:"Playfair Display",serif; font-size:1.4rem; }
  .contact-card p { color:var(--muted); margin:10px 0; }
  .contact-card small { color:var(--rose-dark); font-weight:700; margin-top:auto; }
  .contact-social { display:flex; justify-content:center; align-items:center; flex-wrap:wrap; gap:14px; margin-top:30px; color:var(--muted); }
  @keyframes hero-breathe { from{transform:scale(1)} to{transform:scale(1.025)} }
  @keyframes badge-turn { to{transform:rotate(360deg)} }
  @media(prefers-reduced-motion:reduce){ .hero-slide,.motion-badge{animation:none} }
  @media(max-width: 800px) {
    .hero.section { min-height:auto; padding:26px 0 38px; }
    .hero-grid { grid-template-columns: 1fr; }
    .hero-visual { order: -1; }
    .hero-visual { height:52vh; min-height:390px; }
    .hero-copy h1 { font-size:clamp(2.7rem,13vw,4.3rem); max-width:12ch; }
    .motion-badge { right:8px; width:92px; }
    .section-heading { align-items: flex-start; flex-direction: column; }
    .contact-grid { grid-template-columns:1fr; }
  }
</style>
