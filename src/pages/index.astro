---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CakeCard from "../components/CakeCard.astro";
import TrustBar from "../components/TrustBar.astro";
import OrderForm from "../components/OrderForm.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { site } from "../data/site";
import { optimizedCakeImage } from "../data/images";

const cakes = (await getCollection("cakes", ({ data }) => data.published)).sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const featured = cakes.slice(0, 6);
const heroSlides = cakes.slice(0, 5);
const hero = cakes.find((cake) => cake.data.image.includes("9f3a8b4f")) ?? cakes[0];
const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Bakery"],
  name: site.name,
  url: site.domain,
  image: new URL(hero.data.image, site.domain).toString(),
  telephone: site.phoneDisplay,
  email: site.email,
  priceRange: "££",
  address: {
    "@type": "PostalAddress",
    addressLocality: site.locality,
    addressRegion: site.region,
    addressCountry: site.country
  },
  areaServed: [site.locality, site.region],
  sameAs: [site.instagram, site.tiktok]
};
---
<BaseLayout title="Custom Cakes in Haywards Heath, West Sussex" description={site.primaryDescription} image={hero.data.image} schema={schema}>
  <section class="hero section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Made in Haywards Heath, West Sussex</p>
        <h1>A cake made around your celebration.</h1>
        <p class="lead">Personalised birthday, themed and celebration cakes, handcrafted to match the person, the moment and the flavour you have in mind.</p>
        <div class="actions">
          <a class="button" href="#order">Check your date</a>
          <a class="button button--secondary" href="/gallery/">Browse cake ideas</a>
        </div>
        <div class="hero-social"><span>See the latest cakes</span><SocialLinks /></div>
        <p class="hero-note">Starting from £35. Final quotes depend on size, design and decoration.</p>
      </div>
      <div class="hero-visual" aria-label="A rotating selection of real Gyulrose cake creations">
        {heroSlides.map((cake, index) => <figure class={`hero-slide hero-slide-${index + 1}`}><img src={optimizedCakeImage(cake.data.slug)} alt={index === 0 ? cake.data.imageAlt : ""} width="820" height="920" fetchpriority={index === 0 ? "high" : undefined} /><figcaption><span>{cake.data.flavour}</span><strong>{cake.data.title}</strong><small>From £{cake.data.priceFrom}</small></figcaption></figure>)}
        <div class="motion-badge"><span>Real cakes</span><strong>Made to order</strong></div>
      </div>
    </div>
  </section>
  <TrustBar />

  <section class="section section--white">
    <div class="container">
      <p class="eyebrow">Start with the occasion</p>
      <h2>What are you celebrating?</h2>
      <p class="lead">Choose the closest category, explore real cakes and use any design as a starting point for your own order.</p>
      <div class="grid grid--3 category-grid">
        <a class="category-card birthday" href="/birthday-cakes-haywards-heath/"><span>Birthday cakes</span><strong>Personalised for every age and milestone</strong></a>
        <a class="category-card themed" href="/themed-cakes-haywards-heath/"><span>Children's & themed</span><strong>Characters, hobbies and playful stories</strong></a>
        <a class="category-card celebration" href="/celebration-cakes-west-sussex/"><span>Celebration cakes</span><strong>Anniversaries, graduations and special moments</strong></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Real GyulRose creations</p><h2>A few customer favourites</h2></div><a href="/gallery/">See all cakes</a></div>
      <div class="grid grid--3">{featured.map((cake, index) => <CakeCard cake={cake.data} priority={index < 2} />)}</div>
    </div>
  </section>

  <section id="order" class="section order-section">
    <div class="container">
      <OrderForm compact />
    </div>
  </section>

  <section class="section section--blush">
    <div class="container how-grid">
      <div><p class="eyebrow">Simple ordering</p><h2>From your idea to collection or delivery</h2><p class="lead">Send the cake, date and size. GyulRose will discuss the remaining details with you, so you do not need to complete a long specification.</p><a class="button" href="#order">Start your request</a></div>
      <ol class="steps">
        <li><span>1</span><div><strong>Share the essentials</strong><p>Date, servings, cake style, flavour, budget and collection or delivery.</p></div></li>
        <li><span>2</span><div><strong>Confirm the design and price</strong><p>GyulRose checks availability and agrees the final details with you.</p></div></li>
        <li><span>3</span><div><strong>Your cake is made to order</strong><p>Collect in Haywards Heath or confirm available delivery for your postcode.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="section section--white">
    <div class="container local-grid">
      <div class="local-photo"><img src="/images/cakes/5c2c0b33-9898-48a4-a314-2360dc78159c.jpeg" alt="Personalised floral birthday cake made by GyulRose Cakes" width="720" height="720" loading="lazy" /></div>
      <div><p class="eyebrow">A local, independent cake maker</p><h2>Made in Haywards Heath, for celebrations across nearby West Sussex.</h2><p class="lead">Each cake is prepared to order rather than selected from a factory range. Bring a colour, theme, photograph or simple idea and use the gallery to show the direction you like.</p><div class="actions"><a class="button button--secondary" href="/about/">About GyulRose</a><a class="button button--secondary" href="/delivery-areas/">Delivery and collection</a></div></div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container cta-panel"><div><p class="eyebrow">Still deciding?</p><h2>Save ideas from Instagram and TikTok.</h2><p>Follow GyulRose for new designs, then return to the quick form when you know the style you like.</p></div><SocialLinks /></div>
  </section>
</BaseLayout>
<style>
  .hero { overflow: hidden; }
  .hero.section { padding: 34px 0; }
  .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 54px; align-items: center; }
  .hero-copy { padding: 10px 0; }
  .hero-copy h1 { font-size:clamp(2.35rem, 5.3vw, 4.15rem); }
  .hero-note { margin-top: 18px; color: var(--muted); font-size: .9rem; }
  .hero-social { display:flex; align-items:center; flex-wrap:wrap; gap:12px; margin-top:20px; color:var(--muted); font-size:.85rem; }
  .hero-visual { position: relative; height:min(56vh,530px); perspective:1200px; }
  .hero-slide { position:absolute; inset:0; margin:0; opacity:0; transform:translate3d(8%,4%,0) rotate(2deg) scale(.92); animation:cake-show 25s infinite cubic-bezier(.22,.75,.25,1); }
  .hero-slide img { width:100%; height:100%; object-fit:cover; border-radius:34px; box-shadow:0 26px 70px rgba(63,42,35,.2); }
  .hero-slide figcaption { position:absolute; left:18px; right:18px; bottom:18px; display:grid; grid-template-columns:1fr auto; gap:2px 12px; padding:15px 17px; color:#fff; background:rgba(40,27,24,.72); border:1px solid rgba(255,255,255,.25); border-radius:16px; backdrop-filter:blur(13px); }
  .hero-slide figcaption span { grid-column:1/-1; text-transform:uppercase; letter-spacing:.1em; font-size:.65rem; }
  .hero-slide figcaption strong { font-family:"Playfair Display",serif; font-size:1.08rem; }
  .hero-slide figcaption small { align-self:center; }
  .hero-slide-2{animation-delay:5s}.hero-slide-3{animation-delay:10s}.hero-slide-4{animation-delay:15s}.hero-slide-5{animation-delay:20s}
  .motion-badge { position:absolute; z-index:6; right:-22px; top:18px; width:104px; aspect-ratio:1; display:grid; place-content:center; text-align:center; color:#fff; background:var(--rose); border-radius:50%; box-shadow:var(--shadow); animation:badge-turn 16s linear infinite; }
  .motion-badge span,.motion-badge strong{display:block}.motion-badge span{font-size:.64rem;text-transform:uppercase;letter-spacing:.1em}.motion-badge strong{font-family:"Playfair Display",serif;max-width:8ch;line-height:1.05}
  .order-section { background: linear-gradient(135deg, #f6e7e1, #fffaf6 55%, #f3ddd8); scroll-margin-top: 70px; }
  .category-grid { margin-top: 32px; }
  .category-card { min-height: 230px; border-radius: var(--radius); padding: 25px; display: flex; flex-direction: column; justify-content: flex-end; color: #fff; text-decoration: none; background-size: cover; background-position: center; position: relative; overflow: hidden; }
  .category-card::before { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg,transparent 15%,rgba(35,20,17,.78)); }
  .category-card span, .category-card strong { position: relative; }
  .category-card span { font-weight: 700; font-size: .83rem; text-transform: uppercase; letter-spacing: .08em; }
  .category-card strong { font-family: "Playfair Display",serif; font-size: 1.55rem; margin-top: 5px; }
  .birthday { background-image: url('/images/cakes/7adaeb34-c525-46d0-9f77-4cb3f4746b73.jpeg'); }
  .themed { background-image: url('/images/cakes/17a4c11c-c21c-4fa1-8dfc-2989162bca75.jpeg'); }
  .celebration { background-image: url('/images/cakes/41a40bf6-2683-4e47-8eec-da9e82ae9ac2.jpeg'); }
  .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 32px; }
  .section-heading > a { color: var(--rose-dark); font-weight: 700; }
  .how-grid, .local-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: 56px; align-items: center; }
  .steps { margin: 0; padding: 0; list-style: none; }
  .steps li { display: grid; grid-template-columns: 50px 1fr; gap: 15px; padding: 20px 0; border-bottom: 1px solid #dbc9c1; }
  .steps li > span { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 50%; background: var(--rose); color: #fff; font-weight: 700; }
  .steps p { margin: 5px 0 0; color: var(--muted); }
  .local-photo img { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 28px; }
  .cta-panel { border-radius: 30px; padding: 42px; background: #302724; color: #fff; display: flex; justify-content: space-between; align-items: center; gap: 35px; }
  .cta-panel p { max-width: 680px; color: #dfd1cb; }
  .cta-panel .eyebrow { color: #ffd9df; }
  .cta-panel :global(.social-links) { color:#fff; }
  @keyframes cake-show { 0%{opacity:0;transform:translate3d(8%,4%,0) rotate(2deg) scale(.92)} 4%,17%{opacity:1;transform:translate3d(0,0,0) rotate(0) scale(1)} 20%,100%{opacity:0;transform:translate3d(-7%,-2%,0) rotate(-1deg) scale(1.04)} }
  @keyframes badge-turn { to{transform:rotate(360deg)} }
  @media(prefers-reduced-motion:reduce){ .hero-slide{display:none;animation:none}.hero-slide:first-child{display:block;opacity:1;transform:none}.motion-badge{animation:none} }
  @media(max-width: 800px) {
    .hero-grid, .how-grid, .local-grid { grid-template-columns: 1fr; }
    .hero-visual { order: -1; }
    .hero-visual { height:52vh; min-height:390px; }
    .motion-badge { right:8px; width:92px; }
    .section-heading, .cta-panel { align-items: flex-start; flex-direction: column; }
    .cta-panel { padding: 28px; }
  }
</style>
